{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.base.json",
    ".env.example"
  ],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "GEMINI_API_KEY",
    "REDIS_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_FF_ENABLE_COPILOT",
    "NEXT_PUBLIC_FF_ENABLE_SANDBOX",
    "NEXT_PUBLIC_FF_ENABLE_GRAPH",
    "NEXT_PUBLIC_FF_ENABLE_RESEARCH",
    "NEXT_PUBLIC_FF_ENABLE_DNA",
    "NEXT_PUBLIC_FF_ENABLE_MEMORY",
    "NEXT_PUBLIC_FF_ENABLE_INSIGHTS"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "e2e": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "playwright-report/**",
        "test-results/**"
      ]
    },
    "ai-tests": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}
