# Force strict peer dependency resolution (fails early on discrepancies)
strict-peer-dependencies=true

# Automatically install missing peer dependencies during installation
auto-install-peers=true

# Prevent phantom dependencies by keeping hoisting disabled (pnpm default)
# This prevents code from importing packages that are not explicitly declared in its package.json
shamefully-hoist=false

# Auto-link workspaces in local dev
link-workspace-packages=true

# Standardizes exact package version saves in package.json by default (no ^ or ~)
# This guarantees lockfile stability across all packages
save-exact=true

# Optimized caching settings
prefer-frozen-lockfile=true
