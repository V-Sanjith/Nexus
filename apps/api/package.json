{
  "name": "@nexus/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "python -X utf8 -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8002",
    "db:migrate": "python -m alembic upgrade head",
    "db:rollback": "python -m alembic downgrade -1",
    "db:seed": "python app/db/session.py",
    "lint": "python -m ruff check .",
    "typecheck": "python -m mypy app",
    "test": "python -m pytest"
  }
}
